@model List<DataProvisioning.Domain.Entities.User>
@{
    ViewData["Title"] = "Log In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log In - Babcock Data Provisioning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
</head>
<body style="display: flex; align-items: center; justify-content: center; min-height: 100vh; background-color: var(--bg-primary);">
    <div class="glass-panel animate-fade-in" style="width: 100%; max-width: 400px; padding: 2rem; border-radius: 8px;">
        
        <div style="text-align: center; margin-bottom: 2rem;">
            <img src="~/images/babcock-logo.png" alt="Babcock Logo" style="height: 50px; margin-bottom: 1rem;" onerror="this.style.display='none'" />
            <h2 style="color: var(--text-primary); margin: 0;">Sign In</h2>
            <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">Data Provisioning Portal</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger" role="alert" style="font-size: 0.9rem; padding: 0.75rem;">
                @TempData["ErrorMessage"]
            </div>
        }

        <form asp-controller="Login" asp-action="Authenticate" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            
            <div class="form-group mb-4">
                <label class="form-label" style="font-size: 0.9rem; color: var(--text-secondary);">Select Local Account (Dev Mode)</label>
                <select name="email" class="form-control" required style="background-color: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); color: var(--text-primary);">
                    <option value="">-- Select a User --</option>
                    @foreach (var user in Model)
                    {
                        <option value="@user.Email">@user.Name (@user.Role) - @user.Email</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.6rem; margin-top: 1rem;">Log In</button>
        </form>

        <p style="text-align: center; font-size: 0.8rem; color: var(--text-tertiary); margin-top: 2rem;">
            This utilizes local cookie authentication for development purposes instead of Entra ID.
        </p>
    </div>
</body>
</html>
