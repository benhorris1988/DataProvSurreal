@model DataProvisioning.Application.DTOs.DatasetDetailsDto
@{
    ViewData["Title"] = "Dataset Details";
}

<div style="margin-bottom: 2rem;">
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-secondary" style="margin-bottom: 1rem;">&larr; Back to Catalog</a>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">

    <!-- Left Column: Details & Schema -->
    <div>
        <div class="glass-panel" style="padding: 2rem; margin-bottom: 2rem;">
            <div style="display: flex; justify-content: space-between; align-items: start;">
                <div>
                    <h1 style="margin-bottom: 0.5rem;">
                        @Model.Name
                    </h1>
                    <span class="badge @(Model.Type == "Fact" ? "badge-fact" : "badge-dim")">
                        @Model.Type
                    </span>
                </div>
                @if (Model.IsOwnerOrAdmin)
                {
                    <a asp-controller="Dataset" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                        Edit Dataset
                    </a>
                }
            </div>
            <p style="margin-top: 1.5rem; font-size: 1.1rem;">
                @Html.Raw(Model.Description?.Replace("\n", "<br>"))
            </p>
        </div>

        <!-- Columns Section -->
        <h2 style="margin-bottom: 1rem;">Data Schema</h2>
        <div class="glass-panel table-container">
            <table>
                <thead>
                    <tr>
                        <th>Column Name</th>
                        <th>Type</th>
                        <th>Definition</th>
                        <th>Sample</th>
                        <th>Security</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in Model.Columns)
                    {
                        <tr>
                            <td style="font-weight: 500; color: var(--accent-primary);">
                                @col.Name
                            </td>
                            <td><code>@col.DataType</code></td>
                            <td>
                                @col.Definition
                            </td>
                            <td style="font-family: monospace; font-size: 0.85rem; color: var(--text-secondary);">
                                @col.SampleData
                            </td>
                            <td>
                                @if (col.IsPii)
                                {
                                    <span class="badge" style="background: rgba(239, 68, 68, 0.1); color: var(--accent-danger); border: 1px solid rgba(239, 68, 68, 0.2);">Confidential</span>
                                }
                                else
                                {
                                    <span style="color: var(--accent-success); font-size: 0.8rem;">Open</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Right Column: Request Access -->
    <div>
        <div class="glass-panel" style="padding: 1.5rem; position: sticky; top: 100px;">
            <h3 style="margin-top: 0;">Access Status</h3>

            @if (Model.UserRequests.Any())
            {
                <div style="margin-bottom: 1.5rem;">
                    @foreach (var req in Model.UserRequests)
                    {
                        string statusClass = req.Status switch {
                            "Approved" => "badge-approved",
                            "Pending" => "badge-pending",
                            "Rejected" => "badge-rejected",
                            _ => ""
                        };
                        
                        <div style="margin-bottom: 0.5rem; padding: 0.75rem; background: rgba(255,255,255,0.03); border-radius: 4px; border-left: 3px solid var(--text-secondary);">
                            <strong>@req.PolicyName</strong>
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:0.25rem;">
                                <span class="@statusClass" style="font-size: 0.75rem; padding: 2px 6px;">@req.Status</span>

                                @if (req.Status == "Pending")
                                {
                                    <form asp-action="CancelRequest" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to cancel this request?');">
                                        <input type="hidden" name="requestId" value="@req.Id" />
                                        <input type="hidden" name="datasetId" value="@Model.Id" />
                                        <button type="submit" style="background:none; border:none; color: var(--accent-danger); font-size: 0.75rem; cursor: pointer; text-decoration: underline; margin-left: 1rem;">Cancel Request</button>
                                    </form>
                                }
                                else if (req.Status == "Approved")
                                {
                                    <form asp-action="CancelRequest" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to remove your access?');">
                                        <input type="hidden" name="requestId" value="@req.Id" />
                                        <input type="hidden" name="datasetId" value="@Model.Id" />
                                        <button type="submit" style="background:none; border:none; color: var(--text-secondary); font-size: 0.75rem; cursor: pointer; text-decoration: underline; margin-left: 1rem; opacity: 0.7;">Remove Access</button>
                                    </form>
                                }
                                <span style="font-size: 0.75rem; color: var(--text-secondary);">@req.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>

                            <div style="margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.05); font-size: 0.8rem;">
                                @if (req.Status == "Pending")
                                {
                                    <div style="color: var(--text-secondary); margin-bottom: 0.25rem;">Waiting on:</div>
                                    @foreach (var app in req.PendingApprovers)
                                    {
                                        <div style="margin-bottom: 0.1rem;">
                                            <span style="color: var(--accent-primary); font-weight: bold;">@app.Name</span>
                                            <span style="color: var(--text-secondary); font-size: 0.7rem;">(@app.RoleType)</span>
                                        </div>
                                    }
                                    <div style="color: var(--text-secondary); margin-top: 0.5rem; margin-bottom: 0.2rem;">@Model.GroupName <span style="font-size: 0.7rem;">(Group)</span></div>
                                    
                                    @if (req.GlobalApprovers.Any())
                                    {
                                        <div style="color: var(--text-tertiary); font-size: 0.75rem; margin-top: 0.5rem;">Also approvable by:</div>
                                        @foreach (var ga in req.GlobalApprovers)
                                        {
                                            <div style="font-size: 0.75rem; color: var(--text-secondary);">
                                                @ga.Name <span style="opacity: 0.7;">(@ga.RoleType)</span>
                                            </div>
                                        }
                                    }
                                }
                                else if (req.Status == "Rejected")
                                {
                                    <div style="color: var(--accent-danger); font-weight: bold;">Rejected by: @(req.ReviewerName ?? "Unknown")</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!Model.HasFullAccess)
            {
                @if (!Model.UserRequests.Any())
                {
                    <div style="background: rgba(59, 130, 246, 0.1); border-left: 4px solid var(--accent-primary); padding: 1rem; margin-bottom: 1.5rem;">
                        <p style="margin: 0; font-size: 0.9rem;">You do not have access to this dataset.</p>
                    </div>
                }

                <hr style="border-color: var(--border-color); margin: 1.5rem 0;">
                <h4 style="margin-top: 0; margin-bottom: 1rem;">Request New Access</h4>

                <form asp-action="RequestAccess" method="post">
                    <input type="hidden" name="id" value="@Model.Id">

                    <div class="form-group">
                        <label class="form-label">Justification</label>
                        <textarea name="justification" class="form-control" placeholder="Why do you need this data?" required></textarea>
                    </div>

                    @if (Model.OwnerGroupId == null)
                    {
                        <div style="background: rgba(255, 152, 0, 0.1); border-left: 4px solid var(--accent-warning); padding: 1rem; margin-bottom: 1rem;">
                            <strong style="color: var(--accent-warning);">Request Disabled</strong>
                            <p style="margin: 0.5rem 0 0; font-size: 0.9rem;">This dataset does not have an assigned Owner Group. Please contact an Administrator.</p>
                        </div>
                        <button type="button" class="btn btn-secondary" style="width: 100%; opacity: 0.5; cursor: not-allowed;" disabled>Request Access</button>
                    }
                    else
                    {
                        <div class="form-group">
                            <label class="form-label">Access Policy</label>
                            <select name="policy_group_id" class="form-control" required>
                                <option value="">-- Select Access Policy --</option>
                                @foreach (var p in Model.AvailablePolicies)
                                {
                                    <option value="@p.Id">
                                        @p.Name @(!string.IsNullOrEmpty(p.Description) ? $"({(p.Description.Length > 30 ? p.Description.Substring(0, 30) + "..." : p.Description)})" : "")
                                    </option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary" style="width: 100%;">Request Access</button>
                    }
                </form>
            }
            else
            {
                <div style="background: rgba(34, 197, 94, 0.1); padding: 1rem; border-radius: 4px; text-align: center; color: var(--accent-success);">
                    <strong>Fully Authorized</strong><br>
                    You have full access to this dataset.
                </div>
            }

            <!-- Linked Reports Section -->
            <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border-color);">
                <h4 style="margin-top: 0; margin-bottom: 1rem;">Used In Reports</h4>
                @if (!Model.LinkedReports.Any())
                {
                    <p style="font-size: 0.85rem; color: var(--text-secondary);">No reports linked yet.</p>
                }
                else
                {
                    <ul style="padding-left: 1.25rem; margin: 0; font-size: 0.9rem;">
                        @foreach (var rep in Model.LinkedReports)
                        {
                            <li style="margin-bottom: 0.5rem;">
                                <a href="@rep.Url" target="_blank" style="color: var(--accent-primary); text-decoration: none;">
                                    @rep.Name
                                </a>
                            </li>
                        }
                    </ul>
                }

                @if (Model.IsOwnerOrAdmin)
                {
                    <button type="button" class="btn btn-secondary" style="width: 100%; margin-top: 1rem; font-size: 0.8rem;" data-bs-toggle="modal" data-bs-target="#addReportModal">+ Link Report</button>
                    
                    <!-- Add Report Modal -->
                    <div class="modal fade" id="addReportModal" tabindex="-1" aria-labelledby="addReportModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content text-dark px-2" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                                <form asp-controller="Dataset" asp-action="AddReport" method="post">
                                    <input type="hidden" name="datasetId" value="@Model.Id" />
                                    <div class="modal-header border-bottom-0 pb-0">
                                        <h5 class="modal-title fw-bold" id="addReportModalLabel">Link PowerBI Report</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3 text-start">
                                            <label for="reportName" class="form-label fw-bold">Report Name</label>
                                            <input type="text" class="form-control" id="reportName" name="reportName" required>
                                        </div>
                                        <div class="mb-3 text-start">
                                            <label for="reportUrl" class="form-label fw-bold">Report URL</label>
                                            <input type="url" class="form-control" id="reportUrl" name="reportUrl" placeholder="https://app.powerbi.com/..." required>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-top-0 pt-0">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary px-4">Add Report</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-color);">
                <strong>Owner Group:</strong><br>
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <span>@(Model.GroupName ?? "Unknown")</span>
                    @if (Model.OwnerGroupId != null)
                    {
                        <button style="background: none; border: none; color: var(--accent-primary); cursor: pointer; font-size: 1.2rem;" title="View Group Owner & Members">&#9432;</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
