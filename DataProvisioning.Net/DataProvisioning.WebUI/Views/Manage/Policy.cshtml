@model DataProvisioning.Application.DTOs.ManagePolicyViewModel

@{
    ViewData["Title"] = "Manage Policy";
}

<div class="mb-4">
    <a asp-controller="Manage" asp-action="Index" class="btn btn-outline-secondary">&larr; Back to Manage</a>
    <h1 class="mt-3">Policies: @Model.DatasetName</h1>
    <p class="text-muted">Define Asset Groups (Slices) and their security rules.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <!-- Left: Create New Group -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-white" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
            <div class="card-body">
                <h4 class="card-title h5 mb-3 fw-bold">Create Asset Group</h4>
                <form asp-controller="Manage" asp-action="CreatePolicyGroup" method="post">
                    <input type="hidden" name="datasetId" value="@Model.DatasetId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Group Name</label>
                        <input type="text" name="name" class="form-control" required placeholder="e.g. Nuclear Sector" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" class="form-control" rows="2"></textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Assign IAO</label>
                        <select name="ownerId" class="form-select">
                            <option value="">-- Unassigned --</option>
                            @foreach (var user in Model.AvailableOwners)
                            {
                                <option value="@user.Id">@user.Name</option>
                            }
                        </select>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Create Group</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right: List Groups -->
    <div class="col-md-8">
        @foreach (var group in Model.PolicyGroups)
        {
            <div class="card shadow-sm border-0 mb-4 bg-white" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h3 class="h4 mb-0 fw-bold text-primary">@group.Name</h3>
                        <span class="badge bg-secondary">Owner: @group.OwnerName</span>
                    </div>
                    @if (!string.IsNullOrEmpty(group.Description))
                    {
                         <p class="text-muted small">@group.Description</p>
                    }
                    
                    <hr class="my-4 text-muted opacity-25" />

                    <div class="row g-4">
                        <!-- RLS Section -->
                        <div class="col-md-6 border-end">
                            <h5 class="fw-bold mb-3">Row Level Security (RLS)</h5>
                            
                            <div class="table-responsive mb-3">
                                <table class="table table-sm table-borderless align-middle small">
                                    <tbody>
                                        @foreach (var c in group.Conditions)
                                        {
                                            <tr>
                                                <td class="fw-semibold text-dark">@c.ColumnName</td>
                                                <td class="text-muted font-monospace bg-light rounded px-2 text-center" style="width: 40px;">@c.Operator</td>
                                                <td><span class="badge bg-light text-dark border">@c.Value</span></td>
                                                <td class="text-end" style="width: 30px;">
                                                    <form asp-controller="Manage" asp-action="DeleteCondition" method="post" class="d-inline">
                                                        <input type="hidden" name="datasetId" value="@Model.DatasetId" />
                                                        <input type="hidden" name="conditionId" value="@c.Id" />
                                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Remove Condition">
                                                            <i class="bi bi-x-circle-fill"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                        @if (!group.Conditions.Any())
                                        {
                                            <tr>
                                                <td colspan="4" class="text-muted fst-italic text-center py-2">No conditions applied.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <form asp-controller="Manage" asp-action="AddCondition" method="post" class="d-flex gap-2">
                                <input type="hidden" name="datasetId" value="@Model.DatasetId" />
                                <input type="hidden" name="policyGroupId" value="@group.Id" />
                                
                                <select name="column" class="form-select form-select-sm" required style="width: 120px;">
                                    <option value="">Column...</option>
                                    @foreach (var col in Model.DatasetColumns)
                                    {
                                        <option value="@col.Name">@col.Name</option>
                                    }
                                </select>
                                
                                <select name="op" class="form-select form-select-sm" required style="width: 80px;">
                                    <option value="=">=</option>
                                    <option value="!=">!=</option>
                                    <option value="IN">IN</option>
                                    <option value="LIKE">LIKE</option>
                                </select>
                                
                                <input type="text" name="value" class="form-control form-control-sm" placeholder="Value" required />
                                <button type="submit" class="btn btn-sm btn-primary py-0 px-2 fw-bold">+</button>
                            </form>
                        </div>

                        <!-- CLS Section -->
                        <div class="col-md-6">
                            <h5 class="fw-bold mb-3">Column Level Security (CLS)</h5>
                            <div class="px-2" style="max-height: 250px; overflow-y: auto;">
                                @foreach (var col in Model.DatasetColumns)
                                {
                                    var isHidden = group.Columns.Any(c => c.ColumnName == col.Name && c.IsHidden);
                                    
                                    <form asp-controller="Manage" asp-action="ToggleCls" method="post" class="mb-2">
                                        <input type="hidden" name="datasetId" value="@Model.DatasetId" />
                                        <input type="hidden" name="policyGroupId" value="@group.Id" />
                                        <input type="hidden" name="column" value="@col.Name" />
                                        <!-- Need a hidden field for False values because unchecked checkboxes aren't submitted -->
                                        <input type="hidden" name="isVisible" value="false" />
                                        
                                        <div class="form-check form-switch d-flex align-items-center m-0">
                                            <input class="form-check-input me-2 mt-0" type="checkbox" role="switch" name="isVisible" value="true" 
                                                   onchange="this.form.submit()" @(isHidden ? "" : "checked") />
                                            <label class="form-check-label small w-100" style="@(isHidden ? "text-decoration: line-through; opacity: 0.5;" : "")">
                                                @col.Name
                                                @if (col.IsPii)
                                                {
                                                     <span class="badge bg-danger ms-1" style="font-size: 0.6rem;">PII</span>
                                                }
                                            </label>
                                        </div>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 text-muted opacity-25" />

                    <!-- Authorized Users List -->
                    <div>
                        <h5 class="fw-bold mb-3">Authorized Users (@group.AuthorizedUsers.Count)</h5>
                        @if (group.AuthorizedUsers.Any())
                        {
                            <ul class="list-unstyled mb-0 ms-2 small">
                                @foreach (var user in group.AuthorizedUsers)
                                {
                                    <li class="mb-1 d-flex justify-content-between align-items-center">
                                        <span><i class="bi bi-person text-secondary me-2"></i> @user.Name</span>
                                        <span class="text-muted" style="font-size: 0.8rem;">
                                            Approved: @user.ReviewedAt?.ToString("MMM dd, yyyy")
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted small fst-italic mb-0">No users have been approved for this policy group yet.</p>
                        }
                    </div>
                </div>
            </div>
        }
        
        @if (!Model.PolicyGroups.Any())
        {
             <div class="text-center p-5 text-muted border rounded-3 bg-light">
                 <i class="bi bi-shield-slash fs-1 text-secondary mb-3"></i>
                 <h5>No Policy Groups Defined</h5>
                 <p>Create an asset group on the left to define security rules for this dataset.</p>
             </div>
        }
    </div>
</div>
