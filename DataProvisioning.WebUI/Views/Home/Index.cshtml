@using DataProvisioning.WebUI.Models
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    @@keyframes drawLine {
        to {
            stroke-dashoffset: 0;
        }
    }

    @@keyframes pulse {
        0% { r: 4; stroke-width: 2; opacity: 1; }
        50% { r: 6; stroke-width: 3; opacity: 0.8; }
        100% { r: 4; stroke-width: 2; opacity: 1; }
    }

    .line-anim {
        stroke-dasharray: 2000;
        stroke-dashoffset: 2000;
        animation: drawLine 2.5s ease-out forwards;
        filter: drop-shadow(0 0 4px var(--accent-primary));
    }

    .dot-anim {
        animation: pulse 2s infinite ease-in-out;
    }

    .fade-up-item {
        opacity: 0;
        transform: translateY(10px);
        animation: fadeUp 0.5s ease-out forwards;
    }

    @@keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="header-section" style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end;">
    <div>
        <h1 class="animate-fade-in" style="margin-bottom: 0.5rem;">Dashboard</h1>
        <p style="color: var(--text-secondary); margin: 0;">Welcome back, @Model.UserName.</p>
    </div>
    <div>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary" style="text-decoration: none;">Browse Catalog</a>
    </div>
</div>

<!-- KPI Cards -->
<div class="grid-container" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
    <!-- Active Assets -->
    <div class="card glass-panel animate-fade-in" style="animation-delay: 0.1s; border-left: 4px solid var(--accent-success);">
        <h3 style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">My Active Assets</h3>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-success);">
            @Model.ActiveAssets
        </div>
    </div>

    <!-- Pending Requests -->
    <div class="card glass-panel animate-fade-in" style="animation-delay: 0.2s; border-left: 4px solid #ffc107;">
        <h3 style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Pending Requests</h3>
        <div style="font-size: 2.5rem; font-weight: 800; color: #ffc107;">
            @Model.PendingRequests
        </div>
        @if (Model.PendingRequests > 0)
        {
            <a asp-controller="Requests" asp-action="Index" style="font-size: 0.8rem; color: #ffc107; text-decoration: none;">View Requests &rarr;</a>
        }
    </div>

    <!-- Actions Required (IAO Only) -->
    @if (User.IsInRole("IAO") || User.IsInRole("Admin"))
    {
        <div class="card glass-panel animate-fade-in" style="animation-delay: 0.3s; border-left: 4px solid var(--accent-danger);">
            <h3 style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Actions Required</h3>
            <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-danger);">
                @Model.ActionsRequired
            </div>
            @if (Model.ActionsRequired > 0)
            {
                <a asp-controller="Manage" asp-action="Index" style="font-size: 0.8rem; color: var(--accent-danger); text-decoration: none;">Review Requests &rarr;</a>
            }
        </div>
    }

    <!-- Total Datasets -->
    <div class="card glass-panel animate-fade-in" style="animation-delay: 0.4s; border-left: 4px solid var(--accent-primary);">
        <h3 style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Total Datasets</h3>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-primary);">
            @Model.TotalDatasets
        </div>
    </div>
</div>

<!-- TOP CHARTS ROW: Activity, Inventory, Request Outcome -->
<div class="grid-container" style="grid-template-columns: minmax(400px, 2fr) minmax(280px, 1fr) minmax(280px, 1fr); gap: 1.5rem; margin-bottom: 3rem;">
    <!-- CHART: Activity Trend -->
    <div class="card glass-panel">
        <h3 style="margin-bottom: 1.5rem;">Request Activity (30 Days)</h3>
        <div style="width: 100%; height: 200px; position: relative;">
            <svg viewBox="0 0 1000 200" preserveAspectRatio="none" style="width: 100%; height: 100%; overflow: visible;">
                <defs>
                    <linearGradient id="lineGradient" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="var(--accent-primary)" stop-opacity="0.5" />
                        <stop offset="100%" stop-color="var(--accent-primary)" stop-opacity="0" />
                    </linearGradient>
                </defs>

                <line x1="0" y1="200" x2="1000" y2="200" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
                <line x1="0" y1="100" x2="1000" y2="100" stroke="rgba(255,255,255,0.05)" stroke-width="1" stroke-dasharray="5,5" />
                <line x1="0" y1="0" x2="1000" y2="0" stroke="rgba(255,255,255,0.05)" stroke-width="1" stroke-dasharray="5,5" />

                <polyline points="@Model.ActivitySvgPoints" fill="none" stroke="var(--accent-primary)" stroke-width="3"
                    vector-effect="non-scaling-stroke" stroke-linejoin="round" class="line-anim" />

                <polygon points="@Model.ActivityPolygonPoints" fill="url(#lineGradient)" stroke="none" opacity="0.3"
                    class="fade-up-item" style="animation-delay: 1s;" />

                @foreach (var dot in Model.ActivityDots)
                {
                    <circle cx="@Math.Round(dot.Cx, 2).ToString(System.Globalization.CultureInfo.InvariantCulture)" cy="@Math.Round(dot.Cy, 2).ToString(System.Globalization.CultureInfo.InvariantCulture)" r="4" fill="var(--bg-dark)" stroke="var(--accent-primary)" stroke-width="2" class="fade-up-item dot-anim" style="animation-delay: @(dot.Delay.ToString(System.Globalization.CultureInfo.InvariantCulture))s;" />
                }
            </svg>

            <div style="position: absolute; bottom: -25px; left: 0; font-size: 0.75rem; color: var(--text-secondary);">
                @Model.ActivityLabels[0]
            </div>
            <div style="position: absolute; bottom: -25px; left: 50%; transform: translateX(-50%); font-size: 0.75rem; color: var(--text-secondary);">
                @Model.ActivityLabels[1]
            </div>
            <div style="position: absolute; bottom: -25px; right: 0; font-size: 0.75rem; color: var(--text-secondary);">
                @Model.ActivityLabels[2]
            </div>
        </div>
    </div>

    <!-- CHART: Data Composition (Pie) -->
    <div class="card glass-panel" style="padding: 2rem;">
        <h3 style="margin-bottom: 1.5rem;">Inventory</h3>
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%;">
            @{
                double stop1 = Model.Inventory.FactPct;
                double stop2 = stop1 + Model.Inventory.DimPct;
            }
            <div class="fade-up-item" style="
                width: 140px; 
                height: 140px; 
                border-radius: 50%;
                background: conic-gradient(
                    var(--accent-primary) 0% @(stop1.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%,
                    var(--accent-secondary) @(stop1.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))% @(stop2.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%,
                    var(--text-tertiary) @(stop2.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))% 100%
                );
                position: relative;
                margin-bottom: 1rem;
            ">
                <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 70%; height: 70%; background: #13151a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem;">
                    @Model.Inventory.Total
                </div>
            </div>

            <div style="width: 100%; font-size: 0.8rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span style="display: flex; align-items: center;"><span style="width: 8px; height: 8px; background: var(--accent-primary); border-radius: 50%; margin-right: 6px;"></span> Fact</span>
                    <span>@Math.Round(Model.Inventory.FactPct)%</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span style="display: flex; align-items: center;"><span style="width: 8px; height: 8px; background: var(--accent-secondary); border-radius: 50%; margin-right: 6px;"></span> Dim</span>
                    <span>@Math.Round(Model.Inventory.DimPct)%</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="display: flex; align-items: center;"><span style="width: 8px; height: 8px; background: var(--text-tertiary); border-radius: 50%; margin-right: 6px;"></span> Staging</span>
                    <span>@Math.Round(Model.Inventory.StgPct)%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- CHART: Request Status (Pie) -->
    <div class="card glass-panel" style="padding: 2rem;">
        <h3 style="margin-bottom: 1.5rem;">Request Outcome</h3>
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%;">
            @{
                double s1 = Model.Outcome.ApprovedPct;
                double s2 = s1 + Model.Outcome.PendingPct;
            }
            <div class="fade-up-item" style="
                width: 140px; 
                height: 140px; 
                border-radius: 50%;
                background: conic-gradient(
                    var(--accent-success) 0% @(s1.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%,
                    var(--accent-warning) @(s1.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))% @(s2.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%,
                    var(--accent-danger) @(s2.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))% 100%
                );
                position: relative;
                margin-bottom: 1rem;
            ">
                <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 70%; height: 70%; background: #13151a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem;">
                    @Model.Outcome.Total
                </div>
            </div>

            <div style="width: 100%; font-size: 0.8rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span style="display: flex; align-items: center;"><span style="width: 8px; height: 8px; background: var(--accent-success); border-radius: 50%; margin-right: 6px;"></span> Approved</span>
                    <span>@Math.Round(Model.Outcome.ApprovedPct)%</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span style="display: flex; align-items: center;"><span style="width: 8px; height: 8px; background: var(--accent-warning); border-radius: 50%; margin-right: 6px;"></span> Pending</span>
                    <span>@Math.Round(Model.Outcome.PendingPct)%</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="display: flex; align-items: center;"><span style="width: 8px; height: 8px; background: var(--accent-danger); border-radius: 50%; margin-right: 6px;"></span> Rejected</span>
                    <span>@Math.Round(Model.Outcome.RejectedPct)%</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MIDDLE ROW: Popular | My Recent Access -->
<div class="grid-container" style="grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem;">
    <!-- CHART: Top Datasets -->
    <div class="card glass-panel">
        <h3 style="margin-bottom: 1.5rem;">Popular</h3>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            @if (!Model.TopDatasets.Any())
            {
                <p style="color: var(--text-secondary);">No data yet.</p>
            }
            else
            {
                foreach (var td in Model.TopDatasets)
                {
                    <div class="fade-up-item" style="animation-delay: @((0.5 + (td.Percentage / 200)).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))s;">
                        <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.25rem;">
                            <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px;" title="@td.Name">@td.Name</span>
                            <span style="color: var(--text-secondary);">@td.RequestCount</span>
                        </div>
                        <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;">
                            <div style="width: @(td.Percentage.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%; height: 100%; background: var(--accent-secondary); border-radius: 3px;"></div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- My Recent Access -->
    <div class="card glass-panel" style="padding: 1.5rem;">
        <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">My Recent Access</h3>
        @if (!Model.MyRecentAccess.Any())
        {
            <p style="color: var(--text-secondary);">You haven't been granted access to any datasets yet.</p>
        }
        else
        {
            <ul style="list-style: none; padding: 0;">
                @foreach (var ra in Model.MyRecentAccess)
                {
                    <li style="padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
                        <div style="min-width: 0; flex: 1;">
                            <a asp-controller="Dataset" asp-action="Details" asp-route-id="@ra.Id"
                                style="color: var(--text-primary); text-decoration: none; font-weight: 500; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
                                title="@ra.Name">
                                @ra.Name
                            </a>
                        </div>
                        <div style="font-size: 0.8rem; color: var(--accent-success); white-space: nowrap;">@ra.DateDisplay</div>
                    </li>
                }
            </ul>
        }
    </div>
</div>

<!-- BOTTOM ROW: New to Catalog -->
<div class="grid-container" style="grid-template-columns: 1fr; gap: 2rem;">
    <!-- Recently Added Datasets -->
    <div class="card glass-panel" style="padding: 1.5rem;">
        <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">New to Catalog</h3>
        @if (!Model.NewToCatalog.Any())
        {
            <p style="color: var(--text-secondary);">No datasets available.</p>
        }
        else
        {
            <ul style="list-style: none; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                @foreach (var ds in Model.NewToCatalog)
                {
                    <li style="padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
                        <div style="min-width: 0; flex: 1;">
                            <a asp-controller="Dataset" asp-action="Details" asp-route-id="@ds.Id"
                                style="color: var(--text-primary); text-decoration: none; font-weight: 500; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
                                title="@ds.Name">
                                @ds.Name
                            </a>
                            <div style="margin-top: 2px;">
                                <span class="badge @(ds.Type == "Fact" ? "badge-fact" : "badge-dim")" style="font-size: 0.7rem; padding: 2px 6px;">
                                    @ds.Type
                                </span>
                            </div>
                        </div>
                        <div style="font-size: 0.8rem; color: var(--text-secondary); white-space: nowrap;">
                            @ds.DateDisplay
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>
