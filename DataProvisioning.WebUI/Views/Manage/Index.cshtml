@model DataProvisioning.Application.DTOs.ManageAccessViewModel
@{
    ViewData["Title"] = "Manage Access";
}

<div style="max-width: 1000px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h1>Access Management</h1>
        <button class="btn btn-secondary" onclick="alert('RLS Sync simulation triggered.')" title="Simulated RLS Update">
            &#x2699; Apply RLS Schema
        </button>
    </div>
    <p>Manage pending requests and configure security policies for your Datasets.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert" style="background: rgba(34, 197, 94, 0.1); color: var(--accent-success); border-color: transparent;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- My Datasets Section -->
    <div style="margin-top: 2rem; margin-bottom: 3rem;">
        <h2 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">My Datasets & Policies</h2>

        <div class="glass-panel" style="padding: 0; overflow: hidden; margin-top: 1rem;">
            <table class="data-table" style="width: 100%; border-collapse: collapse;">
                <thead style="background: rgba(255, 255, 255, 0.05); border-bottom: 1px solid var(--border-color);">
                    <tr>
                        <th style="padding: 1rem; text-align: left;">Dataset Name</th>
                        <th style="padding: 1rem; text-align: left; width: 100px;">Type</th>
                        <th style="padding: 1rem; text-align: center; width: 120px;">Policies</th>
                        <th style="padding: 1rem; text-align: center; width: 120px;">Users with Access</th>
                        <th style="padding: 1rem; text-align: right; width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ds in Model.MyDatasets)
                    {
                        <tr style="border-bottom: 1px solid var(--border-color);">
                            <td style="padding: 1rem; font-weight: 500;">
                                @ds.Name
                                @if (ds.IsMissingFromDataWarehouse)
                                {
                                    <span class="badge" style="background: var(--accent-danger); color: white; margin-left: 0.5rem; font-size: 0.7rem;">Table Not Found</span>
                                }
                                <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.2rem;">
                                    @(ds.Description.Length > 50 ? ds.Description.Substring(0, 50) + "..." : ds.Description)
                                </div>
                            </td>
                            <td style="padding: 1rem;">
                                <span class="badge badge-dim">@ds.Type</span>
                            </td>
                            <td style="padding: 1rem; text-align: center; font-size: 1.1rem; font-weight: bold;">
                                @ds.PolicyCount
                            </td>
                            <td style="padding: 1rem; text-align: center; font-size: 1.1rem; font-weight: bold; color: var(--accent-success);">
                                @ds.UserAccessCount
                            </td>
                            <td style="padding: 1rem; text-align: right;">
                                <a asp-controller="Manage" asp-action="Policy" asp-route-id="@ds.Id" class="btn btn-sm btn-outline-primary">Manage Policies</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.MyDatasets.Any())
                    {
                        <tr>
                            <td colspan="5" style="padding: 2rem; text-align: center; color: var(--text-secondary);">You do not own any datasets.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pending Requests Section -->
    <h2 style="margin-top: 3rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem;">
        Pending Requests
        @if (Model.PendingRequests.Any())
        {
            <span class="badge" style="background: var(--accent-danger); color: white;">@Model.PendingRequests.Count</span>
        }
    </h2>

    @if (!Model.PendingRequests.Any())
    {
        <div class="glass-panel" style="padding: 2rem; text-align: center; color: var(--text-secondary);">
            No pending requests at this time.
        </div>
    }
    else
    {
        <div class="grid-container" style="grid-template-columns: 1fr;">
            @foreach (var req in Model.PendingRequests)
            {
                <div class="card glass-panel" style="border-left: 4px solid var(--accent-primary);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                        <div>
                            <h3 style="margin: 0; display: inline-block; margin-right: 1rem;">@req.RequestorName</h3>
                            <span style="color: var(--text-secondary);">requests access to</span>
                            <strong>@req.DatasetName</strong>
                        </div>
                        <span style="font-size: 0.8rem; color: var(--text-secondary);">@req.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>

                    <!-- Approver Context -->
                    <div style="margin-bottom: 1rem; border: 1px dashed rgba(255,255,255,0.1); padding: 0.5rem; border-radius: 4px; font-size: 0.85rem;">
                        <strong style="color: var(--text-secondary);">Data Owner & Approvers:</strong>
                        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.25rem;">
                            @foreach (var app in req.GroupApprovers)
                            {
                                <span class="badge" style="@(app.RoleType == "Owner" ? "background: var(--accent-primary);" : "background: rgba(255,255,255,0.1);") font-weight: normal;">
                                    @app.Name <span style="opacity: 0.7; font-size: 0.7rem;">(@app.RoleType)</span>
                                </span>
                            }
                        </div>
                    </div>

                    <div style="background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem;">
                        <strong>Justification:</strong><br>
                        @req.Justification

                        @if (!string.IsNullOrEmpty(req.RequestedFilters))
                        {
                            <div style="margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.1);">
                                <strong>Requested RLS Filters:</strong> @req.RequestedFilters
                            </div>
                        }
                    </div>

                    <form asp-controller="Manage" asp-action="ProcessRequest" method="post" style="display: flex; gap: 1rem; align-items: center;">
                        <input type="hidden" name="requestId" value="@req.Id">

                        <div style="flex-grow: 1;">
                            <label class="form-label" style="font-size: 0.8rem;">Assign Policy Group</label>
                            <select name="policyGroupId" class="form-control" style="padding: 0.5rem;">
                                <option value="">Full Access (No Policy)</option>
                                @foreach (var pg in req.AvailablePolicies)
                                {
                                    <option value="@pg.Id" selected="@(pg.Id == req.SelectedPolicyGroupId)">@pg.Name</option>
                                }
                            </select>
                        </div>

                        <button type="submit" name="action" value="approve" class="btn btn-primary" style="background: var(--accent-success); border-color: transparent;">Approve</button>
                        <button type="submit" name="action" value="reject" class="btn btn-secondary" style="color: var(--accent-danger); border-color: var(--accent-danger);">Reject</button>
                    </form>
                </div>
            }
        </div>
    }

    <!-- History Section -->
    <h2 style="margin-top: 3rem;">Recent Decisions</h2>
    <div class="glass-panel table-container">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>User</th>
                    <th>Dataset</th>
                    <th>Status</th>
                    <th>Applied Controls</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model.RecentDecisions)
                {
                    <tr>
                        <td>@h.ReviewedAt.ToString("MMM dd, yyyy")</td>
                        <td>@h.RequestorName</td>
                        <td>@h.DatasetName</td>
                        <td>
                            @{
                                string statusClass = h.Status switch {
                                    "Approved" => "badge-approved",
                                    "Rejected" => "badge-rejected",
                                    _ => ""
                                };
                            }
                            <span class="badge @statusClass">@h.Status</span>
                        </td>
                        <td style="font-size: 0.85rem;">
                            @(h.Status == "Approved" ? (h.AppliedPolicyName != null ? "Policy: " + h.AppliedPolicyName : "Full Access") : "-")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
