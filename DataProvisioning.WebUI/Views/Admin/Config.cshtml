@model DataProvisioning.WebUI.Models.AdminConfigViewModel
@{
    ViewData["Title"] = "Admin Centre";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="animate-fade-in">Admin Centre</h1>
        <p class="text-secondary">Manage system configuration and connectivity.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success animate-fade-in fade show" role="alert">
        @TempData["SuccessMessage"]
    </div>
}

<div class="row" style="display: flex; flex-wrap: wrap; margin-right: -15px; margin-left: -15px;">
    <!-- Form side -->
    <div class="col-md-8" style="flex: 0 0 66.666667%; max-width: 66.666667%; padding-right: 15px; padding-left: 15px;">
        <form asp-action="Config" method="post">
            
            <!-- Database Settings (App DB) -->
            <div class="card glass-panel mb-4 animate-fade-in" style="animation-delay: 0.1s; margin-bottom: 1.5rem;">
                <h3 class="mb-3" style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">Database Connection (App)</h3>
                
                <div class="form-group">
                    <label asp-for="DbHost" class="form-label"></label>
                    <input asp-for="DbHost" class="form-control" required />
                    <span asp-validation-for="DbHost" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DbName" class="form-label"></label>
                    <input asp-for="DbName" class="form-control" required />
                    <span asp-validation-for="DbName" class="text-danger"></span>
                </div>

                <div style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="DbUser" class="form-label"></label>
                        <input asp-for="DbUser" class="form-control" required />
                        <span asp-validation-for="DbUser" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="DbPass" class="form-label"></label>
                        <input asp-for="DbPass" type="password" class="form-control" placeholder="Leave blank to keep current" />
                    </div>
                </div>
            </div>

            <!-- Data Warehouse Settings -->
            <div class="card glass-panel mb-4 animate-fade-in" style="animation-delay: 0.15s; margin-bottom: 1.5rem;">
                <h3 class="mb-3" style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">Data Warehouse (Scanning Target)</h3>
                
                <div class="form-group">
                    <label asp-for="DwHost" class="form-label"></label>
                    <input asp-for="DwHost" class="form-control" required />
                    <span asp-validation-for="DwHost" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DwName" class="form-label"></label>
                    <input asp-for="DwName" class="form-control" required />
                    <span asp-validation-for="DwName" class="text-danger"></span>
                </div>

                <div style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="DwUser" class="form-label"></label>
                        <input asp-for="DwUser" class="form-control" required />
                        <span asp-validation-for="DwUser" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="DwPass" class="form-label"></label>
                        <input asp-for="DwPass" type="password" class="form-control" placeholder="Leave blank to keep current" />
                    </div>
                </div>
            </div>

            <!-- AD Settings -->
            <div class="card glass-panel mb-4 animate-fade-in" style="animation-delay: 0.2s; margin-bottom: 1.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">
                    <h3 style="margin: 0;">Active Directory (LDAP)</h3>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <input asp-for="AdEnabled" type="checkbox" style="width: 1.2rem; height: 1.2rem; cursor: pointer;">
                        <label asp-for="AdEnabled" style="margin: 0; cursor: pointer;">Enable</label>
                    </div>
                </div>
                
                <div class="form-group">
                    <label asp-for="AdDomain" class="form-label"></label>
                    <input asp-for="AdDomain" class="form-control" placeholder="example.com" />
                </div>
                <div class="form-group">
                    <label asp-for="AdServer" class="form-label"></label>
                    <input asp-for="AdServer" class="form-control" placeholder="ldap://dc.example.com" />
                </div>
                <div class="form-group">
                    <label asp-for="AdBaseDn" class="form-label"></label>
                    <input asp-for="AdBaseDn" class="form-control" placeholder="DC=example,DC=com" />
                </div>
            </div>

            <!-- Entra ID Settings -->
            <div class="card glass-panel mb-4 animate-fade-in" style="animation-delay: 0.3s; margin-bottom: 1.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">
                    <h3 style="margin: 0;">Microsoft Entra ID (Azure AD)</h3>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <input asp-for="EntraEnabled" type="checkbox" style="width: 1.2rem; height: 1.2rem; cursor: pointer;">
                        <label asp-for="EntraEnabled" style="margin: 0; cursor: pointer;">Enable</label>
                    </div>
                </div>
                
                <div class="form-group">
                    <label asp-for="EntraTenantId" class="form-label"></label>
                    <input asp-for="EntraTenantId" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="EntraClientId" class="form-label"></label>
                    <input asp-for="EntraClientId" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="EntraClientSecret" class="form-label"></label>
                    <input asp-for="EntraClientSecret" type="password" class="form-control" placeholder="Leave blank to keep current secret" />
                </div>
            </div>

            <div style="margin-bottom: 3rem;">
                <button type="submit" class="btn btn-primary" style="padding: 1rem 2rem; font-size: 1.1rem;">Save Configuration</button>
            </div>
        </form>
    </div>

    <!-- System Info side -->
    <div class="col-md-4" style="flex: 0 0 33.333333%; max-width: 33.333333%; padding-right: 15px; padding-left: 15px;">
        <div class="card glass-panel animate-fade-in" style="animation-delay: 0.4s;">
            <h3 style="margin-bottom: 1rem;">System Info</h3>
            <p><strong>.NET Framework:</strong>
                .NET 8.0
            </p>
            <p><strong>Server Software:</strong>
                Kestrel / IIS Express
            </p>
            <p><strong>Target Database:</strong>
                <span style="color: var(--accent-success);">Entity Framework Core (SQL Server)</span>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
