@model IEnumerable<DataProvisioning.Application.DTOs.VirtualGroupDto>
@{
    ViewData["Title"] = "Manage Groups";
    var possibleOwners = ViewBag.PossibleOwners as List<DataProvisioning.Application.DTOs.UserDto>;
    var allUsers = ViewBag.AllUsers as List<DataProvisioning.Application.DTOs.UserDto>;
}

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1>Virtual Groups</h1>
        <button onclick="document.getElementById('createGroupModal').style.display='block'" class="btn btn-primary">
            + Create Group
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert" style="background: rgba(34, 197, 94, 0.1); color: var(--accent-success); border-color: transparent;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert" style="background: rgba(239, 68, 68, 0.1); color: var(--accent-danger); border-color: transparent;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="grid-container">
        @foreach (var g in Model)
        {
            <div class="card glass-panel">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <h3>
                        @g.Name
                        @if (!g.IsOwner && !User.IsInRole("Admin"))
                        {
                            <span class="badge" style="font-size: 0.7rem; background: rgba(255,255,255,0.1); color: var(--text-secondary); margin-left: 0.5rem;">Member View</span>
                        }
                    </h3>
                    @if (g.CanEdit)
                    {
                         <button onclick="openEditModal('@g.Id', '@g.Name', '@g.Description', '@g.OwnerId')" class="btn btn-sm btn-secondary" style="font-size: 0.8rem;">Edit</button>
                    }
                </div>
                <p>@g.Description</p>

                <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem;">
                    <strong>Data Owner:</strong> @g.OwnerName
                </div>

                <div style="margin-top: 1rem; font-size: 0.9rem;">
                    <strong>Controlled Datasets:</strong>
                    @if (g.ControlledDatasets.Any())
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:0.25rem;">
                            @foreach (var ds in g.ControlledDatasets)
                            {
                                <span class="badge" style="background:rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); font-size: 0.8rem;">@ds</span>
                            }
                        </div>
                    }
                    else
                    {
                        <span style="color:var(--text-secondary); font-size:0.85rem; display:block; margin-top:0.25rem;">none</span>
                    }
                </div>

                <hr style="border-color: var(--border-color); margin: 1rem 0;">

                <h4>Members</h4>
                <ul style="list-style: none; padding: 0; margin-bottom: 1rem;">
                    @foreach (var m in g.Members)
                    {
                        <li style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <span>@m.Name</span>
                            <span style="color: var(--text-secondary); font-size: 0.8rem;">@m.Email</span>
                        </li>
                    }
                    @if (!g.Members.Any())
                    {
                        <li style="color: var(--text-secondary); font-style: italic;">No members yet</li>
                    }
                </ul>

                @if (g.CanEdit)
                {
                    <form asp-action="AddGroupMember" method="post" style="display: flex; gap: 0.5rem;">
                        <input type="hidden" name="groupId" value="@g.Id" />
                        <select name="userId" class="form-control" style="font-size: 0.8rem; padding: 0.5rem;" required>
                            <option value="">Select User...</option>
                            @if (allUsers != null)
                            {
                                foreach (var u in allUsers)
                                {
                                    <option value="@u.Id">@u.Name (@u.Email)</option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn btn-secondary" style="padding: 0.5rem 1rem;">Add</button>
                    </form>
                }
                else
                {
                    <div style="font-size: 0.8rem; color: var(--text-secondary); font-style: italic; text-align: center;">
                        Contact the Group Owner to add members.
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Create Group Modal -->
<div id="createGroupModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000;">
    <div class="glass-panel" style="width: 400px; margin: 100px auto; padding: 2rem;">
        <h2>Create New Group</h2>
        <form asp-action="CreateGroup" method="post">
            <div class="form-group">
                <label class="form-label">Group Name</label>
                <input type="text" name="Name" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="Description" class="form-control" required></textarea>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="form-group">
                    <label class="form-label">Group Owner (IAO)</label>
                    <select name="OwnerId" class="form-control">
                        @if(possibleOwners != null)
                        {
                            foreach (var iao in possibleOwners)
                            {
                                <option value="@iao.Id">@iao.Name</option>
                            }
                        }
                    </select>
                </div>
            }

            <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                <button type="button" onclick="document.getElementById('createGroupModal').style.display='none'" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Group Modal -->
<div id="editGroupModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000;">
    <div class="glass-panel" style="width: 400px; margin: 100px auto; padding: 2rem;">
        <h2>Edit Group</h2>
        <form asp-action="UpdateGroup" method="post">
            <input type="hidden" name="Id" id="edit_group_id">
            <div class="form-group">
                <label class="form-label">Group Name</label>
                <input type="text" name="Name" id="edit_group_name" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="Description" id="edit_group_desc" class="form-control" required></textarea>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="form-group">
                    <label class="form-label">Group Owner (IAO)</label>
                    <select name="OwnerId" id="edit_group_owner" class="form-control">
                        @if(possibleOwners != null)
                        {
                            foreach (var iao in possibleOwners)
                            {
                                <option value="@iao.Id">@iao.Name</option>
                            }
                        }
                    </select>
                </div>
            }

            <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                <button type="button" onclick="document.getElementById('editGroupModal').style.display='none'" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditModal(id, name, desc, ownerId) {
        document.getElementById('edit_group_id').value = id;
        document.getElementById('edit_group_name').value = name;
        document.getElementById('edit_group_desc').value = desc;

        var ownerSelect = document.getElementById('edit_group_owner');
        if (ownerSelect) {
            ownerSelect.value = ownerId;
        }

        document.getElementById('editGroupModal').style.display = 'block';
    }

    window.onclick = function (event) {
        if (event.target.classList.contains('modal')) {
            event.target.style.display = "none";
        }
    }
</script>
