@model List<DataProvisioning.Application.DTOs.MyRequestDto>
@{
    ViewData["Title"] = "My Requests";
}

<div style="max-width: 1000px; margin: 0 auto;">
    <h1 class="animate-fade-in" style="margin-bottom: 2rem;">My Access Requests</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="glass-panel animate-fade-in" style="text-align: center; padding: 3rem;">
            <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">You haven't made any requests yet.</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Browse Catalog</a>
        </div>
    }
    else
    {
        <div class="glass-panel table-container animate-fade-in">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Dataset</th>
                        <th>Owner / Approver</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model)
                    {
                        <tr>
                            <td>
                                @req.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td style="font-weight: 500;">
                                <a asp-controller="Dataset" asp-action="Details" asp-route-id="@req.DatasetId"
                                    style="color: var(--text-primary); text-decoration: none;">
                                    @req.DatasetName
                                </a>
                            </td>
                            <td>
                                @if (req.Status == "Rejected")
                                {
                                    <div style="color: var(--accent-danger); font-weight: bold; font-size: 0.9rem;">
                                        Rejected by:
                                        <span style="color: var(--text-primary); font-weight: normal;">
                                            @(req.ReviewerName ?? "Unknown")
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <!-- Display Owner & Members -->
                                    <div style="margin-bottom: 0.5rem;">
                                        @if (!req.PendingApprovers.Any())
                                        {
                                            <div style="font-size: 0.9rem; font-weight: bold; color: var(--accent-primary); margin-bottom: 0.2rem;">
                                                @(req.OwnerName ?? "Unknown")
                                                <span style="font-size: 0.7rem; color: var(--text-secondary); font-weight: normal;">(Owner)</span>
                                            </div>
                                        }
                                        else
                                        {
                                            @foreach (var app in req.PendingApprovers)
                                            {
                                                <div style="font-size: 0.9rem; margin-bottom: 0.2rem;">
                                                    <span style="font-weight: bold; color: var(--accent-primary);">
                                                        @app.Name
                                                    </span>
                                                    <span style="font-size: 0.7rem; color: var(--text-secondary);">
                                                        (@app.RoleType)
                                                    </span>
                                                </div>
                                            }
                                        }
                                        <div style="font-size: 0.75rem; color: var(--text-secondary);">
                                            @(req.GroupName ?? "-")
                                        </div>
                                    </div>

                                    @if (req.GlobalApprovers.Any() && req.Status == "Pending")
                                    {
                                        <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 0.25rem;">
                                            <div style="font-size: 0.7rem; color: var(--text-tertiary); margin-bottom: 0.1rem;">Also approvable by:</div>
                                            @foreach (var ga in req.GlobalApprovers)
                                            {
                                                <div style="font-size: 0.8rem; color: var(--text-secondary);">
                                                    @ga.Name
                                                    <span style="font-size: 0.7rem; opacity: 0.7;">(@ga.RoleType)</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </td>
                            <td>
                                @{
                                    string statusClass = req.Status switch {
                                        "Approved" => "badge-approved",
                                        "Pending" => "badge-pending",
                                        "Rejected" => "badge-rejected",
                                        _ => ""
                                    };
                                }
                                <span class="badge @statusClass">
                                    @req.Status
                                </span>
                            </td>
                            <td>
                                @if (req.Status == "Pending")
                                {
                                    <form asp-action="CancelRequest" method="post" onsubmit="return confirm('Are you sure you want to cancel this request?');">
                                        <input type="hidden" name="requestId" value="@req.Id" />
                                        <button type="submit" class="btn btn-sm btn-secondary"
                                            style="color: var(--accent-danger); border-color: var(--accent-danger); padding: 0.2rem 0.6rem; font-size: 0.8rem;">
                                            Cancel
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color: var(--text-tertiary); font-size: 0.8rem;">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
